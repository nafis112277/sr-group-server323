# সার্ভার পোর্ট (Render নিজেই এটা সেট করে দেয়, চিন্তা করতে হবে না)
PORT=3000

# Neon থেকে পাওয়া PostgreSQL connection string।
# Neon ড্যাশবোর্ডে "Connection string" এ ক্লিক করলে এরকম একটা লিংক পাবেন:
# postgresql://user:password@ep-something.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# JWT সাইন করার জন্য গোপন কী — অবশ্যই একটা লম্বা, র‍্যান্ডম স্ট্রিং দিয়ে বদলে দিন
JWT_SECRET=change-this-to-a-long-random-string

# Gemini API key — এটা শুধু সার্ভারে থাকবে, ব্রাউজারে কখনো পাঠানো হবে না
#
# একটাই key থাকলে এটা ব্যবহার করুন:
GEMINI_API_KEY=your-gemini-api-key-here
#
# একাধিক key থাকলে (Google-এর free quota দ্রুত শেষ হয়ে যায় বলে এটা বেশি কার্যকর),
# GEMINI_API_KEYS-এ কমা দিয়ে সবগুলো বসান — একটার quota শেষ হলে সার্ভার নিজে থেকেই
# পরের key দিয়ে চেষ্টা করবে। এটা থাকলে উপরের GEMINI_API_KEY লাগবে না।
# GEMINI_API_KEYS=key-one,key-two,key-three

# চাইলে মডেল পাল্টাতে পারেন (যেমন gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash

# অ্যাডমিন ড্যাশবোর্ডের প্রথমবারের ডিফল্ট পাসকোড — লগইন করেই এটা বদলে ফেলুন
ADMIN_DEFAULT_PASSCODE=srgroup2026
